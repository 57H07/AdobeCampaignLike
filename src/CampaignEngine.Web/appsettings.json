{
  "AllowedHosts": "*",

  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.MSSqlServer" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning",
        "CampaignEngine": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {CorrelationId} {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/campaignengine-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {CorrelationId} {SourceContext} {Message:lj}{NewLine}{Exception}",
          "fileSizeLimitBytes": 52428800,
          "rollOnFileSizeLimit": true
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/campaignengine-errors-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 90,
          "restrictedToMinimumLevel": "Error",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {CorrelationId} {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithEnvironmentName" ],
    "Properties": {
      "Application": "CampaignEngine"
    }
  },

  "ConnectionStrings": {
    "DefaultConnection": "Server=(local);Database=CampaignEngine;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True"
  },

  "CampaignEngine": {
    "BatchProcessing": {
      "ChunkSize": 500,
      "WorkerCount": 8,
      "MaxRetryAttempts": 3,
      "RetryDelaysSeconds": [ 30, 120, 600 ]
    },
    "Dispatch": {
      "Email": {
        "ThrottlePerSecond": 100
      },
      "Sms": {
        "ThrottlePerSecond": 10
      }
    },
    "RateLimit": {
      "Email": {
        "TokensPerSecond": 100,
        "MaxWaitTimeSeconds": 30,
        "BurstMultiplier": 2.0
      },
      "Sms": {
        "TokensPerSecond": 10,
        "MaxWaitTimeSeconds": 10,
        "BurstMultiplier": 2.0
      },
      "Letter": {
        "TokensPerSecond": 0,
        "MaxWaitTimeSeconds": 0,
        "BurstMultiplier": 1.0
      }
    },
    "Templates": {
      "Storage": {
        "RootPath": "templates"
      }
    },
    "Attachments": {
      "AllowedExtensions": [ ".pdf", ".docx", ".xlsx", ".png", ".jpg" ],
      "MaxFileSizeBytes": 10485760,
      "MaxTotalSizeBytes": 26214400,
      "Storage": {
        "BasePath": "attachments",
        "AllowedExtensions": [ ".pdf", ".docx", ".xlsx", ".png", ".jpg", ".jpeg" ],
        "MaxFileSizeBytes": 10485760,
        "MaxTotalSizeBytes": 26214400
      }
    },
    "Rendering": {
      "TimeoutSeconds": 10
    },
    "SendLog": {
      "RetentionDays": 90
    },
    "Logging": {
      "SqlErrorSinkEnabled": false,
      "SqlTableName": "ApplicationLogs",
      "RetentionDays": 30
    }
  },

  "Smtp": {
    "Host": "",
    "Port": 587,
    "UseSsl": true,
    "UserName": "",
    "Password": "",
    "FromAddress": "",
    "FromName": "CampaignEngine",
    "ReplyToAddress": "",
    "TimeoutSeconds": 30,
    "MaxConnectRetries": 3,
    "AllowedAttachmentExtensions": [ ".pdf", ".docx", ".xlsx", ".png", ".jpg", ".jpeg" ],
    "MaxAttachmentFileSizeBytes": 10485760,
    "MaxAttachmentTotalSizeBytes": 26214400
  },

  "Sms": {
    "ProviderApiUrl": "",
    "ApiKey": "",
    "DefaultSenderId": ""
  },

  "ApiKey": {
    "DefaultExpiresInDays": 365,
    "DefaultRateLimitPerMinute": 1000,
    "RequireHttps": true
  },

  "Hangfire": {
    "DashboardPath": "/hangfire",
    "WorkerCount": 8
  },

  "Swagger": {
    "Enabled": true
  },

  "SqlServerConnector": {
    "ConnectTimeoutSeconds": 30,
    "MinPoolSize": 0,
    "MaxPoolSize": 100
  },

  "Letter": {
    "IsEnabled": true,
    "OutputDirectory": "",
    "MaxPagesPerBatch": 500,
    "GenerateManifest": true,
    "FileNamePrefix": "CAMPAIGN",
    "WriteIndividualFiles": false
  },

  "DefaultAdmin": {
    "UserName": "admin",
    "Email": "admin@campaignengine.local",
    "Password": "Admin@1234!",
    "DisplayName": "Default Administrator"
  }
}
