{
  "AllowedHosts": "*",

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "CampaignEngine": "Information"
    }
  },

  "ConnectionStrings": {
    "DefaultConnection": "Server=(local);Database=CampaignEngine;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True"
  },

  "CampaignEngine": {
    "BatchProcessing": {
      "ChunkSize": 500,
      "WorkerCount": 8,
      "MaxRetryAttempts": 3,
      "RetryDelaysSeconds": [ 30, 120, 600 ]
    },
    "Dispatch": {
      "Email": {
        "ThrottlePerSecond": 100
      },
      "Sms": {
        "ThrottlePerSecond": 10
      }
    },
    "Attachments": {
      "AllowedExtensions": [ ".pdf", ".docx", ".xlsx", ".png", ".jpg" ],
      "MaxFileSizeBytes": 10485760,
      "MaxTotalSizeBytes": 26214400
    },
    "Rendering": {
      "TimeoutSeconds": 10
    },
    "SendLog": {
      "RetentionDays": 90
    }
  },

  "Smtp": {
    "Host": "",
    "Port": 587,
    "UseSsl": true,
    "UserName": "",
    "Password": "",
    "FromAddress": "",
    "FromName": "CampaignEngine"
  },

  "Sms": {
    "ProviderApiUrl": "",
    "ApiKey": "",
    "DefaultSenderId": ""
  },

  "Hangfire": {
    "DashboardPath": "/hangfire",
    "WorkerCount": 8
  },

  "Swagger": {
    "Enabled": true
  }
}
