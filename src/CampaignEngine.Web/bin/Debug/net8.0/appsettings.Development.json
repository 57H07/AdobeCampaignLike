{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information",
      "CampaignEngine": "Debug"
    }
  },

  "ConnectionStrings": {
    "DefaultConnection": "Server=(local);Database=CampaignEngine_Dev;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True"
  },

  "Swagger": {
    "Enabled": true
  },

  "CampaignEngine": {
    "BatchProcessing": {
      "ChunkSize": 50,
      "WorkerCount": 2
    }
  }
}
