@page "{id:guid}"
@model CampaignEngine.Web.Pages.Templates.TemplateDetailModel
@{
    ViewData["Title"] = Model.Template?.Name ?? "Template Detail";
}

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="alert">
        @Model.StatusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (Model.Template is null)
{
    <div class="alert alert-warning">Template not found.</div>
    <a asp-page="Index" class="btn btn-outline-secondary">Back to list</a>
}
else
{
    var channelBadge = Model.Template.Channel switch
    {
        "Email"  => "bg-primary",
        "Letter" => "bg-warning text-dark",
        "Sms"    => "bg-success",
        _        => "bg-secondary"
    };
    var statusBadge = Model.Template.Status switch
    {
        "Published" => "bg-success",
        "Draft"     => "bg-secondary",
        "Archived"  => "bg-danger",
        _           => "bg-secondary"
    };

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="mb-1">@Model.Template.Name</h1>
            <span class="badge @channelBadge me-1">@Model.Template.Channel</span>
            <span class="badge @statusBadge">@Model.Template.Status</span>
            @if (Model.Template.IsSubTemplate)
            {
                <span class="badge bg-info ms-1">Sub-template</span>
            }
        </div>
        <div class="d-flex gap-2 flex-wrap">
            @if (User.IsInRole("Designer") || User.IsInRole("Admin"))
            {
                @* Publish button — only shown for Draft templates *@
                @if (Model.Template.Status == "Draft")
                {
                    <form method="post" asp-page-handler="Publish" asp-route-id="@Model.Template.Id" style="display:inline;">
                        <button type="submit" class="btn btn-success"
                                onclick="return confirm('Publish template \'@Model.Template.Name\'?\n\nOnce published, this template will be available for campaign creation.')">
                            <i class="bi bi-send-check"></i> Publish
                        </button>
                    </form>
                }

                @* Archive button — shown for Draft and Published templates *@
                @if (Model.Template.Status != "Archived")
                {
                    <form method="post" asp-page-handler="Archive" asp-route-id="@Model.Template.Id" style="display:inline;">
                        <button type="submit" class="btn btn-outline-danger"
                                onclick="return confirm('Archive template \'@Model.Template.Name\'?\n\nArchived templates cannot be used in new campaigns and cannot be un-archived.')">
                            <i class="bi bi-archive"></i> Archive
                        </button>
                    </form>
                }

                @if (Model.Template.Status != "Archived")
                {
                    <a asp-page="Edit" asp-route-id="@Model.Template.Id" class="btn btn-outline-primary">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                }
            }
            <a asp-page="History" asp-route-id="@Model.Template.Id" class="btn btn-outline-info">
                <i class="bi bi-clock-history"></i> Version History
            </a>
            <a asp-page="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    <div class="row g-4">
        @* Metadata card *@
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-header"><h6 class="mb-0">Metadata</h6></div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-5">ID</dt>
                        <dd class="col-7"><code style="font-size:0.75em">@Model.Template.Id</code></dd>

                        <dt class="col-5">Channel</dt>
                        <dd class="col-7"><span class="badge @channelBadge">@Model.Template.Channel</span></dd>

                        <dt class="col-5">Status</dt>
                        <dd class="col-7"><span class="badge @statusBadge">@Model.Template.Status</span></dd>

                        <dt class="col-5">Version</dt>
                        <dd class="col-7">v@Model.Template.Version</dd>

                        <dt class="col-5">Sub-template</dt>
                        <dd class="col-7">@(Model.Template.IsSubTemplate ? "Yes" : "No")</dd>

                        <dt class="col-5">Created</dt>
                        <dd class="col-7"><small>@Model.Template.CreatedAt.ToString("yyyy-MM-dd HH:mm")</small></dd>

                        <dt class="col-5">Updated</dt>
                        <dd class="col-7"><small>@Model.Template.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</small></dd>

                        @if (!string.IsNullOrEmpty(Model.Template.Description))
                        {
                            <dt class="col-5">Description</dt>
                            <dd class="col-7">@Model.Template.Description</dd>
                        }
                    </dl>
                </div>
            </div>
        </div>

        @* HTML Body card *@
        <div class="col-md-8">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">HTML Body</h6>
                    <small class="text-muted">Scriban template syntax</small>
                </div>
                <div class="card-body p-0">
                    <pre class="p-3 mb-0" style="max-height:500px; overflow:auto; font-size:0.8em; white-space:pre-wrap; background:#f8f9fa;">@Model.Template.HtmlBody</pre>
                </div>
            </div>
        </div>
    </div>

    @* Placeholder Manifest section *@
    <div class="row g-4 mt-1">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">Placeholder Manifest</h6>
                    <div class="d-flex align-items-center gap-2">
                        @if (Model.ValidationResult is not null)
                        {
                            if (Model.ValidationResult.IsComplete && Model.ValidationResult.OrphanKeys.Count == 0)
                            {
                                <span class="badge bg-success">Complete</span>
                            }
                            else if (Model.ValidationResult.IsComplete)
                            {
                                <span class="badge bg-warning text-dark">Orphan entries</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Incomplete</span>
                            }
                        }
                        @if (User.IsInRole("Designer") || User.IsInRole("Admin"))
                        {
                            <a asp-page="Manifest" asp-route-id="@Model.Template.Id" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil-square"></i> Edit Manifest
                            </a>
                        }
                    </div>
                </div>
                <div class="card-body">
                    @if (Model.ValidationResult is not null && !Model.ValidationResult.IsComplete)
                    {
                        <div class="alert alert-warning mb-3" role="alert">
                            <strong>Incomplete manifest:</strong> @Model.ValidationResult.Summary
                        </div>
                    }

                    @if (Model.Template.PlaceholderManifests.Count == 0)
                    {
                        <p class="text-muted mb-0">No placeholder manifest entries declared for this template.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Key</th>
                                        <th>Type</th>
                                        <th>Source</th>
                                        <th>Description</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var entry in Model.Template.PlaceholderManifests.OrderBy(e => e.Key))
                                    {
                                        var typeBadge = entry.Type switch
                                        {
                                            "Scalar"    => "bg-primary",
                                            "Table"     => "bg-info text-dark",
                                            "List"      => "bg-secondary",
                                            "FreeField" => "bg-warning text-dark",
                                            _           => "bg-secondary"
                                        };
                                        <tr>
                                            <td><code>{{ @entry.Key }}</code></td>
                                            <td><span class="badge @typeBadge">@entry.Type</span></td>
                                            <td>
                                                @if (entry.IsFromDataSource)
                                                {
                                                    <span class="text-success"><i class="bi bi-database"></i> Data Source</span>
                                                }
                                                else
                                                {
                                                    <span class="text-warning"><i class="bi bi-person-fill"></i> Operator Input</span>
                                                }
                                            </td>
                                            <td><small class="text-muted">@(entry.Description ?? "—")</small></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}
