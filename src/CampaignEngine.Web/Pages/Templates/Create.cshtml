@page
@model CampaignEngine.Web.Pages.Templates.CreateTemplateModel
@{
    ViewData["Title"] = "Create Template";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Create Template</h1>
    <a asp-page="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back to list
    </a>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                <form method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Input.Name" class="form-label">Name <span class="text-danger">*</span></label>
                        <input asp-for="Input.Name" class="form-control" placeholder="e.g. Welcome Email" />
                        <span asp-validation-for="Input.Name" class="text-danger"></span>
                        <div class="form-text">Must be unique within the selected channel.</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Channel" class="form-label">Channel <span class="text-danger">*</span></label>
                        <select asp-for="Input.Channel" class="form-select" id="channelSelector">
                            <option value="">-- Select channel --</option>
                            <option value="1" selected>Email</option>
                            <option value="2">Letter</option>
                            <option value="3">SMS</option>
                        </select>
                        <span asp-validation-for="Input.Channel" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Description" class="form-label">Description</label>
                        <input asp-for="Input.Description" class="form-control" placeholder="Optional description of the template's purpose" />
                        <span asp-validation-for="Input.Description" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="Input.IsSubTemplate" class="form-check-input" type="checkbox" role="switch" id="isSubTemplateSwitch" />
                            <label class="form-check-label" for="isSubTemplateSwitch">
                                <i class="bi bi-puzzle-fill text-info"></i>
                                <strong>Sub-template block</strong>
                                <span class="text-muted ms-1">— make this template reusable in parent templates</span>
                            </label>
                        </div>
                        <div class="form-text">
                            Sub-templates can be embedded in other templates using
                            <code>{{&gt; template_name}}</code> syntax.
                        </div>
                    </div>

                    @* HTML editor section: shown for Email and SMS, hidden for Letter *@
                    <div class="mb-3" id="htmlEditorSection">
                        <label asp-for="Input.BodyPath" class="form-label">Body Path <span class="text-danger">*</span></label>
                        <input asp-for="Input.BodyPath" class="form-control"
                               placeholder="e.g. templates/{id}/v1.html" />
                        <span asp-validation-for="Input.BodyPath" class="text-danger"></span>
                        <div class="form-text">
                            Relative path from storage root to the template body file.
                        </div>
                    </div>

                    @* File upload section: shown only for Letter channel *@
                    <div class="mb-3" id="fileUploadSection" style="display:none;">
                        <label for="Input_DocxFile" class="form-label">
                            DOCX File <span class="text-danger">*</span>
                        </label>
                        <input type="file"
                               id="Input_DocxFile"
                               name="Input.DocxFile"
                               class="form-control"
                               accept=".docx" />
                        <span id="docxFileValidation" class="text-danger" style="display:none;">
                            A .docx file is required for Letter templates.
                        </span>
                        <div class="form-text">
                            Upload a <strong>.docx</strong> file. The file path will be set automatically.
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary" id="submitBtn">
                            <i class="bi bi-floppy"></i> Create Template
                        </button>
                        <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header"><h6 class="mb-0">Channel Guide</h6></div>
            <div class="card-body">
                <ul class="list-unstyled mb-0">
                    <li class="mb-2">
                        <span class="badge bg-primary">Email</span>
                        HTML email with CSS inlining. Supports attachments and CC.
                    </li>
                    <li class="mb-2">
                        <span class="badge bg-warning text-dark">Letter</span>
                        Upload a DOCX file. Placeholders use <code>{{ }}</code> syntax.
                    </li>
                    <li>
                        <span class="badge bg-success">SMS</span>
                        Plain text extracted and truncated to 160 characters.
                    </li>
                </ul>
            </div>
        </div>

        <div class="card mt-3" id="letterHintCard" style="display:none;">
            <div class="card-header bg-warning bg-opacity-10">
                <h6 class="mb-0 text-warning-emphasis">
                    <i class="bi bi-file-earmark-word me-1"></i> DOCX Template Tips
                </h6>
            </div>
            <div class="card-body">
                <p class="small mb-2">Use double-brace placeholders directly in your Word document:</p>
                <ul class="list-unstyled small font-monospace mb-0">
                    <li class="mb-1"><code>{{ firstName }}</code> — scalar value</li>
                    <li class="mb-1"><code>{{ address.street }}</code> — nested field</li>
                    <li><code>{{ for item in items }}<br />...<br />{{ end }}</code> — list</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            var LETTER_VALUE = '2';

            var channelSelector = document.getElementById('channelSelector');
            var htmlEditorSection = document.getElementById('htmlEditorSection');
            var fileUploadSection = document.getElementById('fileUploadSection');
            var letterHintCard = document.getElementById('letterHintCard');
            var docxFileInput = document.getElementById('Input_DocxFile');
            var docxFileValidation = document.getElementById('docxFileValidation');
            var bodyPathInput = document.querySelector('input[name="Input.BodyPath"]');

            function toggleSections() {
                var isLetter = channelSelector.value === LETTER_VALUE;

                if (isLetter) {
                    htmlEditorSection.style.display = 'none';
                    fileUploadSection.style.display = '';
                    letterHintCard.style.display = '';
                    // BodyPath is not required for Letter — set a placeholder value
                    if (bodyPathInput) {
                        bodyPathInput.removeAttribute('required');
                        bodyPathInput.value = '';
                    }
                } else {
                    htmlEditorSection.style.display = '';
                    fileUploadSection.style.display = 'none';
                    letterHintCard.style.display = 'none';
                    docxFileValidation.style.display = 'none';
                    if (bodyPathInput) {
                        bodyPathInput.setAttribute('required', 'required');
                    }
                }
            }

            // Client-side validation: file required for Letter
            document.querySelector('form').addEventListener('submit', function (e) {
                if (channelSelector.value !== LETTER_VALUE) return;

                if (!docxFileInput.files || docxFileInput.files.length === 0) {
                    e.preventDefault();
                    docxFileValidation.style.display = '';
                    docxFileInput.focus();
                    return false;
                }

                var file = docxFileInput.files[0];
                if (!file.name.toLowerCase().endsWith('.docx')) {
                    e.preventDefault();
                    docxFileValidation.textContent = 'Only .docx files are accepted for Letter templates.';
                    docxFileValidation.style.display = '';
                    docxFileInput.focus();
                    return false;
                }

                // Hide any previous validation message
                docxFileValidation.style.display = 'none';
            });

            // Hide validation message when user selects a file
            docxFileInput.addEventListener('change', function () {
                docxFileValidation.style.display = 'none';
            });

            // Wire up the channel selector
            channelSelector.addEventListener('change', toggleSections);

            // Run on page load to apply default state (Email selected)
            toggleSections();
        })();
    </script>
}
