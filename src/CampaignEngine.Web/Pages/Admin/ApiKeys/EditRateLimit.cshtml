@page "{id:guid}"
@model CampaignEngine.Web.Pages.Admin.ApiKeys.EditRateLimitModel
@{
    ViewData["Title"] = "Edit Rate Limit";
}

<h1>Edit Rate Limit</h1>
<p class="text-muted">Update the per-minute rate limit for this API key. The new limit takes effect immediately.</p>

@if (Model.ApiKey is not null)
{
    <div class="card mb-4">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Key Name</dt>
                <dd class="col-sm-9"><strong>@Model.ApiKey.Name</strong></dd>
                <dt class="col-sm-3">Key Prefix</dt>
                <dd class="col-sm-9"><code>@Model.ApiKey.KeyPrefix...</code></dd>
                <dt class="col-sm-3">Current Rate Limit</dt>
                <dd class="col-sm-9">@(Model.ApiKey.RateLimitPerMinute.HasValue ? $"{Model.ApiKey.RateLimitPerMinute}/min" : "Default (1000/min)")</dd>
            </dl>
        </div>
    </div>
}

<div class="row">
    <div class="col-md-6">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Input.RateLimitPerMinute" class="form-label">Rate Limit (requests/minute)</label>
                <input asp-for="Input.RateLimitPerMinute" class="form-control" type="number" min="1" max="100000" />
                <span asp-validation-for="Input.RateLimitPerMinute" class="text-danger small"></span>
                <div class="form-text">
                    Leave blank to reset to the system default (1000 requests/minute).
                    Valid range: 1 to 100,000.
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-circle"></i> Save Rate Limit
                </button>
                <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
    <div class="col-md-6">
        <div class="card border-info">
            <div class="card-header bg-info bg-opacity-10">
                <i class="bi bi-info-circle"></i> Rate Limiting Notes
            </div>
            <div class="card-body small">
                <ul class="mb-0">
                    <li>Rate limiting uses a <strong>sliding 1-minute window</strong>.</li>
                    <li>Requests exceeding the limit receive a <strong>429 Too Many Requests</strong> response.</li>
                    <li>The <code>Retry-After</code> header indicates when the window resets.</li>
                    <li>Every response includes <code>X-RateLimit-Limit</code>, <code>X-RateLimit-Remaining</code>, and <code>X-RateLimit-Reset</code> headers.</li>
                    <li>Changes take effect on the next request from this key.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
