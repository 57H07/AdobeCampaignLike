@page
@model CampaignEngine.Web.Pages.Admin.ApiKeys.CreateModel
@{
    ViewData["Title"] = "Create API Key";
}

<h1>Create API Key</h1>
<p class="text-muted">API keys allow external systems to call the Send API. The plaintext key is shown only once after creation.</p>

<div class="row">
    <div class="col-md-6">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Input.Name" class="form-label">Key Name <span class="text-danger">*</span></label>
                <input asp-for="Input.Name" class="form-control" placeholder="e.g. CRM Integration, Mobile App" />
                <span asp-validation-for="Input.Name" class="text-danger small"></span>
                <div class="form-text">A unique, descriptive name for this key.</div>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Description" class="form-label">Description</label>
                <textarea asp-for="Input.Description" class="form-control" rows="2"
                          placeholder="Optional notes about the consumer of this key"></textarea>
                <span asp-validation-for="Input.Description" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.ExpiresInDays" class="form-label">Expires In (days)</label>
                <input asp-for="Input.ExpiresInDays" class="form-control" type="number" min="1" max="3650" />
                <span asp-validation-for="Input.ExpiresInDays" class="text-danger small"></span>
                <div class="form-text">Default: 365 days (1 year). Leave blank for a key that never expires.</div>
            </div>

            <div class="mb-3">
                <label asp-for="Input.RateLimitPerMinute" class="form-label">Rate Limit (requests/minute)</label>
                <input asp-for="Input.RateLimitPerMinute" class="form-control" type="number" min="1" max="100000" />
                <span asp-validation-for="Input.RateLimitPerMinute" class="text-danger small"></span>
                <div class="form-text">Leave blank to use the system default (1000 requests/minute).</div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> Create Key
                </button>
                <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
    <div class="col-md-6">
        <div class="card border-info">
            <div class="card-header bg-info bg-opacity-10">
                <i class="bi bi-info-circle"></i> Security Notes
            </div>
            <div class="card-body small">
                <ul class="mb-0">
                    <li>The full key value is shown <strong>only once</strong> after creation.</li>
                    <li>Keys are hashed with BCrypt — the plaintext is never stored.</li>
                    <li>Revoked keys stop working immediately.</li>
                    <li>Use the X-Api-Key HTTP header to authenticate API calls.</li>
                    <li>Rate limits protect against abuse and ensure fair resource usage.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
