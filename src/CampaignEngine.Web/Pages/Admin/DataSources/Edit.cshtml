@page "{id:guid}"
@model CampaignEngine.Web.Pages.Admin.DataSources.EditModel
@{
    ViewData["Title"] = "Edit Data Source";
}

<div class="d-flex align-items-center mb-3">
    <a asp-page="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i> Back
    </a>
    <div>
        <h1 class="mb-0">Edit Data Source</h1>
        <p class="text-muted mb-0">Update connection metadata. Leave connection string blank to keep existing.</p>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <form method="post">
            <div asp-validation-summary="All" class="alert alert-danger" style="display:none;"></div>

            <div class="card mb-4">
                <div class="card-header"><h6 class="mb-0">Connection Details</h6></div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="Input.Name" class="form-label">Name <span class="text-danger">*</span></label>
                        <input asp-for="Input.Name" class="form-control" />
                        <span asp-validation-for="Input.Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Description" class="form-label">Description</label>
                        <textarea asp-for="Input.Description" class="form-control" rows="2"></textarea>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Type" class="form-label">Type <span class="text-danger">*</span></label>
                        <select asp-for="Input.Type" class="form-select">
                            <option value="1">SQL Server</option>
                            <option value="2">REST API</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.ConnectionString" class="form-label">New Connection String</label>
                        <div class="input-group">
                            <input asp-for="Input.ConnectionString"
                                   type="password"
                                   id="connectionStringInput"
                                   class="form-control font-monospace"
                                   placeholder="Leave blank to keep existing encrypted string" />
                            <button type="button" class="btn btn-outline-secondary" id="toggleCsVisibility">
                                <i class="bi bi-eye" id="eyeIcon"></i>
                            </button>
                        </div>
                        <div class="form-text">
                            <i class="bi bi-shield-lock text-success"></i>
                            The existing connection string is stored encrypted. Enter a new value only if you want to replace it.
                        </div>
                    </div>

                    <button type="button" class="btn btn-outline-info btn-sm" id="testConnectionBtn">
                        <i class="bi bi-plug"></i> Test New Connection
                    </button>
                    <span id="testResult" class="ms-2 small" style="display:none;"></span>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save"></i> Save Changes
                </button>
                <a asp-page="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('toggleCsVisibility').addEventListener('click', function () {
            const input = document.getElementById('connectionStringInput');
            const icon = document.getElementById('eyeIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'bi bi-eye-slash';
            } else {
                input.type = 'password';
                icon.className = 'bi bi-eye';
            }
        });

        document.getElementById('testConnectionBtn').addEventListener('click', async function () {
            const typeVal = document.querySelector('[name="Input.Type"]').value;
            const cs = document.getElementById('connectionStringInput').value;
            const resultEl = document.getElementById('testResult');

            if (!cs) {
                resultEl.style.display = 'inline';
                resultEl.className = 'ms-2 small text-warning';
                resultEl.textContent = 'Enter a new connection string first.';
                return;
            }

            this.disabled = true;
            resultEl.style.display = 'inline';
            resultEl.className = 'ms-2 small text-muted';
            resultEl.textContent = 'Testing...';

            try {
                const response = await fetch('/api/datasources/test-connection', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ type: parseInt(typeVal), connectionString: cs })
                });

                if (response.ok) {
                    const data = await response.json();
                    resultEl.className = data.success ? 'ms-2 small text-success' : 'ms-2 small text-danger';
                    resultEl.textContent = data.message;
                } else {
                    resultEl.className = 'ms-2 small text-danger';
                    resultEl.textContent = 'Test failed (HTTP ' + response.status + ')';
                }
            } catch (e) {
                resultEl.className = 'ms-2 small text-danger';
                resultEl.textContent = 'Network error: ' + e.message;
            }

            this.disabled = false;
        });
    </script>
}
