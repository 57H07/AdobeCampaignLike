@page
@model CampaignEngine.Web.Pages.Admin.DataSources.IndexModel
@{
    ViewData["Title"] = "Data Source Management";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-1">Data Sources</h1>
        <p class="text-muted mb-0">Manage external data repositories for recipient targeting.</p>
    </div>
    <a asp-page="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> New Data Source
    </a>
</div>

@if (Model.StatusMessage != null)
{
    <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="alert">
        @Model.StatusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@* ------------------------------------------------------------------ *@
@* Filter Panel                                                         *@
@* ------------------------------------------------------------------ *@
<div class="card mb-4">
    <div class="card-header">
        <h6 class="mb-0">Filters</h6>
    </div>
    <div class="card-body">
        <form method="get" asp-page="Index">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Name</label>
                    <input type="text" class="form-control" name="nameContains"
                           value="@Model.Filter.NameContains" placeholder="Search by name..." />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Type</label>
                    <select class="form-select" name="type">
                        <option value="">All Types</option>
                        <option value="1" selected="@(Model.Filter.TypeValue == "1")">SQL Server</option>
                        <option value="2" selected="@(Model.Filter.TypeValue == "2")">REST API</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Status</label>
                    <select class="form-select" name="isActive">
                        <option value="">All</option>
                        <option value="true" selected="@(Model.Filter.IsActiveValue == "true")">Active</option>
                        <option value="false" selected="@(Model.Filter.IsActiveValue == "false")">Inactive</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-secondary w-100">Filter</button>
                    <a asp-page="Index" class="btn btn-outline-secondary w-100">Reset</a>
                </div>
            </div>
        </form>
    </div>
</div>

@* ------------------------------------------------------------------ *@
@* Data Source Table                                                    *@
@* ------------------------------------------------------------------ *@
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Data Sources (@Model.TotalCount)</span>
    </div>
    <div class="card-body p-0">
        @if (!Model.DataSources.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-database fs-1"></i>
                <p class="mt-2">No data sources found. <a asp-page="Create">Create the first one.</a></p>
            </div>
        }
        else
        {
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Name</th>
                        <th>Type</th>
                        <th>Fields</th>
                        <th>Status</th>
                        <th>Connection</th>
                        <th>Updated</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ds in Model.DataSources)
                    {
                        <tr>
                            <td>
                                <a asp-page="Details" asp-route-id="@ds.Id" class="fw-semibold text-decoration-none">
                                    @ds.Name
                                </a>
                                @if (!string.IsNullOrEmpty(ds.Description))
                                {
                                    <br /><small class="text-muted">@ds.Description</small>
                                }
                            </td>
                            <td>
                                @{
                                    var typeBadge = ds.Type == CampaignEngine.Domain.Enums.DataSourceType.SqlServer
                                        ? "bg-info text-dark"
                                        : "bg-warning text-dark";
                                }
                                <span class="badge @typeBadge">@ds.TypeName</span>
                            </td>
                            <td>
                                <span class="badge bg-secondary">@ds.Fields.Count fields</span>
                            </td>
                            <td>
                                @if (ds.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>
                                @if (ds.HasConnectionString)
                                {
                                    <span class="text-success"><i class="bi bi-shield-lock"></i> Encrypted</span>
                                }
                                else
                                {
                                    <span class="text-danger"><i class="bi bi-exclamation-triangle"></i> Not configured</span>
                                }
                            </td>
                            <td>
                                <small class="text-muted">@ds.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</small>
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a asp-page="Details" asp-route-id="@ds.Id"
                                       class="btn btn-outline-secondary" title="View Details">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-page="Edit" asp-route-id="@ds.Id"
                                       class="btn btn-outline-primary" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form method="post" asp-page-handler="ToggleActive" asp-route-id="@ds.Id"
                                          style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="isActive" value="@(!ds.IsActive)" />
                                        <button type="submit"
                                                class="btn @(ds.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                                title="@(ds.IsActive ? "Deactivate" : "Activate")">
                                            <i class="bi @(ds.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
    @* Pagination *@
    @if (Model.TotalPages > 1)
    {
        <div class="card-footer">
            <nav>
                <ul class="pagination pagination-sm mb-0 justify-content-center">
                    @for (int p = 1; p <= Model.TotalPages; p++)
                    {
                        <li class="page-item @(p == Model.CurrentPage ? "active" : "")">
                            <a class="page-link"
                               asp-page="Index"
                               asp-route-page="@p"
                               asp-route-nameContains="@Model.Filter.NameContains"
                               asp-route-type="@Model.Filter.TypeValue"
                               asp-route-isActive="@Model.Filter.IsActiveValue">@p</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>
