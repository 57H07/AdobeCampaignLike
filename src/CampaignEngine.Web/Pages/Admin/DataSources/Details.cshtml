@page "{id:guid}"
@model CampaignEngine.Web.Pages.Admin.DataSources.DetailsModel
@{
    ViewData["Title"] = $"Data Source: {Model.DataSource?.Name}";
}

@if (Model.DataSource is null)
{
    <div class="alert alert-danger">Data source not found.</div>
    <a asp-page="Index" class="btn btn-secondary">Back to List</a>
    return;
}

<div class="d-flex align-items-center mb-3">
    <a asp-page="Index" class="btn btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i> Back
    </a>
    <div class="flex-grow-1">
        <h1 class="mb-0">@Model.DataSource.Name</h1>
        <p class="text-muted mb-0">@(Model.DataSource.Description ?? "No description")</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-page="Edit" asp-route-id="@Model.DataSource.Id" class="btn btn-primary">
            <i class="bi bi-pencil"></i> Edit
        </a>
        <a asp-page="FilterBuilder" asp-route-id="@Model.DataSource.Id" class="btn btn-outline-success">
            <i class="bi bi-funnel"></i> Filter Builder
        </a>
        <form method="post" asp-page-handler="TestConnection" asp-route-id="@Model.DataSource.Id">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-info">
                <i class="bi bi-plug"></i> Test Connection
            </button>
        </form>
    </div>
</div>

@if (Model.StatusMessage != null)
{
    <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="alert">
        @Model.StatusMessage
        @if (Model.TestResult != null)
        {
            <br /><small>Elapsed: @Model.TestResult.ElapsedMs ms — Tested at @Model.TestResult.TestedAt.ToString("HH:mm:ss") UTC</small>
        }
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <div class="col-md-4">
        <div class="card mb-4">
            <div class="card-header"><h6 class="mb-0">Connection Details</h6></div>
            <div class="card-body">
                <dl class="mb-0">
                    <dt class="text-muted small">Type</dt>
                    <dd>
                        @{
                            var typeBadge = Model.DataSource.Type == CampaignEngine.Domain.Enums.DataSourceType.SqlServer
                                ? "bg-info text-dark"
                                : "bg-warning text-dark";
                        }
                        <span class="badge @typeBadge">@Model.DataSource.TypeName</span>
                    </dd>

                    <dt class="text-muted small mt-2">Status</dt>
                    <dd>
                        @if (Model.DataSource.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </dd>

                    <dt class="text-muted small mt-2">Connection String</dt>
                    <dd>
                        @if (Model.DataSource.HasConnectionString)
                        {
                            <span class="text-success">
                                <i class="bi bi-shield-lock"></i> Encrypted at rest
                            </span>
                        }
                        else
                        {
                            <span class="text-danger">
                                <i class="bi bi-exclamation-triangle"></i> Not configured
                            </span>
                        }
                    </dd>

                    <dt class="text-muted small mt-2">Created</dt>
                    <dd>@Model.DataSource.CreatedAt.ToString("yyyy-MM-dd HH:mm") UTC</dd>

                    <dt class="text-muted small mt-2">Last Updated</dt>
                    <dd>@Model.DataSource.UpdatedAt.ToString("yyyy-MM-dd HH:mm") UTC</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0">Field Schema (@Model.DataSource.Fields.Count fields)</h6>
                <a asp-page="EditSchema" asp-route-id="@Model.DataSource.Id" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-list-ul"></i> Edit Schema
                </a>
            </div>
            @if (Model.DataSource.Fields.Any())
            {
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Field Name</th>
                                <th>Data Type</th>
                                <th>Filterable</th>
                                <th>Recipient Address</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var field in Model.DataSource.Fields)
                            {
                                <tr>
                                    <td class="font-monospace">@field.FieldName</td>
                                    <td><span class="badge bg-light text-dark">@field.DataType</span></td>
                                    <td>
                                        @if (field.IsFilterable)
                                        {
                                            <i class="bi bi-check-circle-fill text-success"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-x-circle text-muted"></i>
                                        }
                                    </td>
                                    <td>
                                        @if (field.IsRecipientAddress)
                                        {
                                            <i class="bi bi-person-fill text-primary"></i>
                                        }
                                    </td>
                                    <td><small class="text-muted">@(field.Description ?? "-")</small></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="card-body text-center text-muted py-4">
                    <i class="bi bi-table fs-2"></i>
                    <p class="mt-2">No fields defined yet. <a asp-page="EditSchema" asp-route-id="@Model.DataSource.Id">Define schema</a> to enable filtering.</p>
                </div>
            }
        </div>
    </div>
</div>
