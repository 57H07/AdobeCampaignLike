@page "{id:guid}"
@model CampaignEngine.Web.Pages.Campaigns.CampaignDetailModel
@{
    ViewData["Title"] = Model.Campaign is not null ? $"Campaign — {Model.Campaign.Name}" : "Campaign Not Found";
}

@if (Model.Campaign is null)
{
    <div class="alert alert-warning">Campaign not found.</div>
    <a asp-page="Index" class="btn btn-secondary">Back to List</a>
    return;
}

<div class="d-flex align-items-center mb-3">
    <a asp-page="Index" class="btn btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i> Back
    </a>
    <div>
        <h1 class="mb-0">@Model.Campaign.Name</h1>
        <p class="text-muted mb-0">Campaign details</p>
    </div>
</div>

@{
    var statusBadge = Model.Campaign.Status switch
    {
        "Draft"         => "bg-secondary",
        "Scheduled"     => "bg-primary",
        "Running"       => "bg-warning text-dark",
        "StepInProgress"=> "bg-warning text-dark",
        "WaitingNext"   => "bg-info text-dark",
        "Completed"     => "bg-success",
        "PartialFailure"=> "bg-danger",
        "ManualReview"  => "bg-danger",
        _               => "bg-secondary"
    };
}

<div class="row g-4">
    <!-- Campaign summary -->
    <div class="col-lg-5">
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0">Summary</h6>
                <span class="badge @statusBadge">@Model.Campaign.Status</span>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Name</dt>
                    <dd class="col-sm-7">@Model.Campaign.Name</dd>

                    <dt class="col-sm-5">Data Source</dt>
                    <dd class="col-sm-7">@(Model.Campaign.DataSourceName ?? "—")</dd>

                    <dt class="col-sm-5">Scheduled At</dt>
                    <dd class="col-sm-7">
                        @(Model.Campaign.ScheduledAt.HasValue
                            ? Model.Campaign.ScheduledAt.Value.ToString("yyyy-MM-dd HH:mm") + " UTC"
                            : "Immediate")
                    </dd>

                    <dt class="col-sm-5">Created By</dt>
                    <dd class="col-sm-7">@(Model.Campaign.CreatedBy ?? "—")</dd>

                    <dt class="col-sm-5">Created At</dt>
                    <dd class="col-sm-7">@Model.Campaign.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
                </dl>
            </div>
        </div>

        @if (Model.Campaign.Status != "Draft")
        {
            var snap = Model.StatusSnapshot;
            var pctLive = snap is not null && snap.TotalRecipients > 0
                ? snap.ProgressPercent : 0;
            var barColorLive = snap is not null && snap.TotalRecipients > 0 && snap.FailureCount > 0
                ? (snap.FailureRatePercent >= 10 ? "bg-danger"
                    : snap.FailureRatePercent >= 2 ? "bg-warning"
                    : "bg-success")
                : "bg-success";

            <div class="card mb-4" id="progressCard">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">Progress</h6>
                    @if (Model.IsActive)
                    {
                        <small class="text-muted">
                            <span class="spinner-border spinner-border-sm text-warning me-1" role="status"></span>
                            Live — auto-refreshes every 10 s
                        </small>
                    }
                </div>
                <div class="card-body" id="progressBody">
                    <dl class="row mb-2">
                        <dt class="col-sm-6">Total Recipients</dt>
                        <dd class="col-sm-6" id="totalRecipients">@(snap?.TotalRecipients ?? Model.Campaign.TotalRecipients)</dd>
                        <dt class="col-sm-6">Processed</dt>
                        <dd class="col-sm-6" id="processedCount">@(snap?.ProcessedCount ?? Model.Campaign.ProcessedCount)</dd>
                        <dt class="col-sm-6">Success</dt>
                        <dd class="col-sm-6 text-success" id="successCount">@(snap?.SuccessCount ?? Model.Campaign.SuccessCount)</dd>
                        <dt class="col-sm-6">Failures</dt>
                        <dd class="col-sm-6 text-danger" id="failureCount">@(snap?.FailureCount ?? Model.Campaign.FailureCount)</dd>
                        @if (snap is not null && snap.TotalRecipients > 0)
                        {
                            <dt class="col-sm-6">Failure Rate</dt>
                            <dd class="col-sm-6 @(snap.FailureRatePercent >= 10 ? "text-danger fw-bold" : snap.FailureRatePercent >= 2 ? "text-warning" : "text-muted")" id="failureRate">
                                @snap.FailureRatePercent.ToString("0.00")%
                                @if (snap.FailureRatePercent >= 10)
                                {
                                    <span class="badge bg-danger ms-1">Manual Review</span>
                                }
                                else if (snap.FailureRatePercent >= 2)
                                {
                                    <span class="badge bg-warning text-dark ms-1">Partial Failure</span>
                                }
                            </dd>
                        }
                    </dl>
                    @if ((snap?.TotalRecipients ?? Model.Campaign.TotalRecipients) > 0)
                    {
                        <div class="progress" style="height:10px;" id="progressBarWrapper"
                             title="@pctLive% processed — @(snap?.FailureCount ?? 0) failed">
                            <div class="progress-bar @barColorLive" id="progressBar"
                                 style="width:@pctLive%;"
                                 role="progressbar"
                                 aria-valuenow="@pctLive" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        <div class="d-flex justify-content-between mt-1">
                            <small class="text-muted" id="progressLabel">@pctLive% processed</small>
                            @if (snap?.StartedAt.HasValue == true)
                            {
                                <small class="text-muted">Started: @snap.StartedAt.Value.ToString("yyyy-MM-dd HH:mm") UTC</small>
                            }
                            @if (snap?.CompletedAt.HasValue == true)
                            {
                                <small class="text-muted">Completed: @snap.CompletedAt.Value.ToString("yyyy-MM-dd HH:mm") UTC</small>
                            }
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Template Snapshots (US-025) -->
        @if (Model.Snapshots.Any())
        {
            <div class="card mb-4">
                <div class="card-header">
                    <a class="text-decoration-none text-body d-flex justify-content-between"
                       data-bs-toggle="collapse" href="#snapshotPanel" role="button">
                        <span><i class="bi bi-camera"></i> Template Snapshots (@Model.Snapshots.Count)</span>
                        <i class="bi bi-chevron-down"></i>
                    </a>
                </div>
                <div class="collapse show" id="snapshotPanel">
                    <div class="card-body p-0">
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Template Name</th>
                                    <th>Channel</th>
                                    <th>Version</th>
                                    <th>Frozen At</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var snap in Model.Snapshots)
                                {
                                    var snapChannelBadge = snap.Channel switch
                                    {
                                        "Email"  => "bg-primary",
                                        "Letter" => "bg-warning text-dark",
                                        "Sms"    => "bg-success",
                                        _        => "bg-secondary"
                                    };
                                    <tr>
                                        <td>
                                            <small class="fw-semibold">@snap.Name</small>
                                            <br/>
                                            <small class="text-muted font-monospace" title="Snapshot ID">@snap.Id</small>
                                        </td>
                                        <td><span class="badge @snapChannelBadge">@snap.Channel</span></td>
                                        <td><span class="badge bg-light text-dark border">v@snap.TemplateVersion</span></td>
                                        <td><small>@snap.CreatedAt.ToString("yyyy-MM-dd HH:mm")</small></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        <div class="p-2 border-top">
                            <small class="text-muted">
                                <i class="bi bi-lock-fill text-success"></i>
                                Snapshots are immutable — template edits after scheduling do not affect this campaign.
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Campaign steps -->
    <div class="col-lg-7">
        <div class="card mb-4">
            <div class="card-header">
                <h6 class="mb-0">Campaign Steps (@Model.Campaign.Steps.Count)</h6>
            </div>
            <div class="card-body p-0">
                @if (Model.Campaign.Steps.Any())
                {
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Step</th>
                                <th>Channel</th>
                                <th>Template</th>
                                <th>Delay</th>
                                <th>Snapshot</th>
                                <th>Executed</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var step in Model.Campaign.Steps)
                            {
                                var channelBadge = step.Channel switch
                                {
                                    "Email"  => "bg-primary",
                                    "Letter" => "bg-warning text-dark",
                                    "Sms"    => "bg-success",
                                    _        => "bg-secondary"
                                };
                                <tr>
                                    <td class="text-center fw-semibold">@step.StepOrder</td>
                                    <td><span class="badge @channelBadge">@step.Channel</span></td>
                                    <td><small>@step.TemplateId</small></td>
                                    <td>
                                        @if (step.DelayDays == 0)
                                        {
                                            <small class="text-muted">Immediate</small>
                                        }
                                        else
                                        {
                                            <small>+@step.DelayDays day(s)</small>
                                        }
                                    </td>
                                    <td>
                                        @if (step.TemplateSnapshotId.HasValue)
                                        {
                                            <span class="badge bg-success" title="Snapshot ID: @step.TemplateSnapshotId">
                                                <i class="bi bi-lock-fill"></i> Frozen
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-muted border">Not scheduled</span>
                                        }
                                    </td>
                                    <td>
                                        @if (step.ExecutedAt.HasValue)
                                        {
                                            <small>@step.ExecutedAt.Value.ToString("yyyy-MM-dd HH:mm")</small>
                                        }
                                        else
                                        {
                                            <small class="text-muted">Pending</small>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="p-3 text-muted">No steps defined.</div>
                }
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Campaign.FilterExpression) && Model.Campaign.FilterExpression != "[]")
        {
            <div class="card mb-4">
                <div class="card-header">
                    <a class="text-decoration-none text-body d-flex justify-content-between"
                       data-bs-toggle="collapse" href="#filterExprPanel" role="button">
                        <span><i class="bi bi-funnel"></i> Filter Expression (AST)</span>
                        <i class="bi bi-chevron-down"></i>
                    </a>
                </div>
                <div class="collapse" id="filterExprPanel">
                    <div class="card-body p-0">
                        <pre class="mb-0 p-3 bg-light rounded-bottom small" style="max-height:200px; overflow-y:auto;">@Model.Campaign.FilterExpression</pre>
                    </div>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.Campaign.FreeFieldValues))
        {
            <div class="card mb-4">
                <div class="card-header">
                    <a class="text-decoration-none text-body d-flex justify-content-between"
                       data-bs-toggle="collapse" href="#freeFieldPanel" role="button">
                        <span><i class="bi bi-input-cursor-text"></i> Free Field Values</span>
                        <i class="bi bi-chevron-down"></i>
                    </a>
                </div>
                <div class="collapse" id="freeFieldPanel">
                    <div class="card-body p-0">
                        <pre class="mb-0 p-3 bg-light rounded-bottom small" style="max-height:200px; overflow-y:auto;">@Model.Campaign.FreeFieldValues</pre>
                    </div>
                </div>
            </div>
        }

        @* ------------------------------------------------------------------ *@
        @* Status Transition History (US-027)                                  *@
        @* ------------------------------------------------------------------ *@
        @if (Model.StatusSnapshot is not null && Model.StatusSnapshot.History.Any())
        {
            <div class="card mb-4">
                <div class="card-header">
                    <a class="text-decoration-none text-body d-flex justify-content-between"
                       data-bs-toggle="collapse" href="#statusHistoryPanel" role="button">
                        <span><i class="bi bi-clock-history"></i> Status History (@Model.StatusSnapshot.History.Count)</span>
                        <i class="bi bi-chevron-down"></i>
                    </a>
                </div>
                <div class="collapse show" id="statusHistoryPanel">
                    <div class="card-body p-0">
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Timestamp (UTC)</th>
                                    <th>From</th>
                                    <th></th>
                                    <th>To</th>
                                    <th>Reason</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var entry in Model.StatusSnapshot.History.OrderByDescending(h => h.OccurredAt))
                                {
                                    var fromBadge = entry.FromStatus switch
                                    {
                                        "Draft"          => "bg-secondary",
                                        "Scheduled"      => "bg-primary",
                                        "Running"        => "bg-warning text-dark",
                                        "StepInProgress" => "bg-warning text-dark",
                                        "WaitingNext"    => "bg-info text-dark",
                                        "Completed"      => "bg-success",
                                        "PartialFailure" => "bg-danger",
                                        "ManualReview"   => "bg-danger",
                                        _                => "bg-secondary"
                                    };
                                    var toBadge = entry.ToStatus switch
                                    {
                                        "Draft"          => "bg-secondary",
                                        "Scheduled"      => "bg-primary",
                                        "Running"        => "bg-warning text-dark",
                                        "StepInProgress" => "bg-warning text-dark",
                                        "WaitingNext"    => "bg-info text-dark",
                                        "Completed"      => "bg-success",
                                        "PartialFailure" => "bg-danger",
                                        "ManualReview"   => "bg-danger",
                                        _                => "bg-secondary"
                                    };
                                    <tr>
                                        <td class="text-nowrap">
                                            <small>@entry.OccurredAt.ToString("yyyy-MM-dd HH:mm:ss")</small>
                                        </td>
                                        <td><span class="badge @fromBadge">@entry.FromStatus</span></td>
                                        <td class="text-muted text-center"><i class="bi bi-arrow-right"></i></td>
                                        <td><span class="badge @toBadge">@entry.ToStatus</span></td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(entry.Reason))
                                            {
                                                <small class="text-muted">@entry.Reason</small>
                                            }
                                            else
                                            {
                                                <small class="text-muted">—</small>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@* ------------------------------------------------------------------ *@
@* Live progress auto-refresh (US-027) — active campaigns only        *@
@* ------------------------------------------------------------------ *@
@if (Model.IsActive)
{
    <script>
        (function () {
            var campaignId = '@Model.Campaign.Id';
            var intervalMs = 10000; // 10 seconds

            function refreshProgress() {
                fetch('/api/campaigns/' + campaignId + '/status', {
                    headers: { 'Accept': 'application/json' },
                    credentials: 'same-origin'
                })
                .then(function (res) { return res.ok ? res.json() : null; })
                .then(function (data) {
                    if (!data) return;

                    var total      = data.totalRecipients || 0;
                    var processed  = data.processedCount || 0;
                    var success    = data.successCount || 0;
                    var failure    = data.failureCount || 0;
                    var pct        = total > 0 ? Math.round(processed * 100 / total) : 0;
                    var failRate   = total > 0 ? (failure * 100 / total) : 0;
                    var barColor   = failure > 0 && total > 0
                        ? (failRate >= 10 ? 'bg-danger' : failRate >= 2 ? 'bg-warning' : 'bg-success')
                        : 'bg-success';

                    var el = function (id) { return document.getElementById(id); };

                    if (el('totalRecipients'))  el('totalRecipients').textContent  = total;
                    if (el('processedCount'))   el('processedCount').textContent   = processed;
                    if (el('successCount'))     el('successCount').textContent     = success;
                    if (el('failureCount'))     el('failureCount').textContent     = failure;
                    if (el('progressLabel'))    el('progressLabel').textContent    = pct + '% processed';

                    var bar = el('progressBar');
                    if (bar) {
                        bar.style.width      = pct + '%';
                        bar.className        = 'progress-bar ' + barColor;
                        bar.setAttribute('aria-valuenow', pct);
                    }

                    // Stop polling when terminal status reached
                    var terminal = ['Completed', 'PartialFailure', 'ManualReview'];
                    if (terminal.indexOf(data.status) !== -1) {
                        clearInterval(timer);
                        window.location.reload();
                    }
                })
                .catch(function () { /* silent — keep polling */ });
            }

            var timer = setInterval(refreshProgress, intervalMs);
        })();
    </script>
}
