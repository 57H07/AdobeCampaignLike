@page "{id:guid}"
@model CampaignEngine.Web.Pages.Campaigns.CampaignDetailModel
@{
    ViewData["Title"] = Model.Campaign is not null ? $"Campaign — {Model.Campaign.Name}" : "Campaign Not Found";
}

@if (Model.Campaign is null)
{
    <div class="alert alert-warning">Campaign not found.</div>
    <a asp-page="Index" class="btn btn-secondary">Back to List</a>
    return;
}

<div class="d-flex align-items-center mb-3">
    <a asp-page="Index" class="btn btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i> Back
    </a>
    <div>
        <h1 class="mb-0">@Model.Campaign.Name</h1>
        <p class="text-muted mb-0">Campaign details</p>
    </div>
</div>

@{
    var statusBadge = Model.Campaign.Status switch
    {
        "Draft"         => "bg-secondary",
        "Scheduled"     => "bg-primary",
        "Running"       => "bg-warning text-dark",
        "StepInProgress"=> "bg-warning text-dark",
        "WaitingNext"   => "bg-info text-dark",
        "Completed"     => "bg-success",
        "PartialFailure"=> "bg-danger",
        "ManualReview"  => "bg-danger",
        _               => "bg-secondary"
    };
}

<div class="row g-4">
    <!-- Campaign summary -->
    <div class="col-lg-5">
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0">Summary</h6>
                <span class="badge @statusBadge">@Model.Campaign.Status</span>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Name</dt>
                    <dd class="col-sm-7">@Model.Campaign.Name</dd>

                    <dt class="col-sm-5">Data Source</dt>
                    <dd class="col-sm-7">@(Model.Campaign.DataSourceName ?? "—")</dd>

                    <dt class="col-sm-5">Scheduled At</dt>
                    <dd class="col-sm-7">
                        @(Model.Campaign.ScheduledAt.HasValue
                            ? Model.Campaign.ScheduledAt.Value.ToString("yyyy-MM-dd HH:mm") + " UTC"
                            : "Immediate")
                    </dd>

                    <dt class="col-sm-5">Created By</dt>
                    <dd class="col-sm-7">@(Model.Campaign.CreatedBy ?? "—")</dd>

                    <dt class="col-sm-5">Created At</dt>
                    <dd class="col-sm-7">@Model.Campaign.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
                </dl>
            </div>
        </div>

        @if (Model.Campaign.Status != "Draft")
        {
            <div class="card mb-4">
                <div class="card-header"><h6 class="mb-0">Progress</h6></div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-6">Total Recipients</dt>
                        <dd class="col-sm-6">@Model.Campaign.TotalRecipients</dd>
                        <dt class="col-sm-6">Processed</dt>
                        <dd class="col-sm-6">@Model.Campaign.ProcessedCount</dd>
                        <dt class="col-sm-6">Success</dt>
                        <dd class="col-sm-6 text-success">@Model.Campaign.SuccessCount</dd>
                        <dt class="col-sm-6">Failures</dt>
                        <dd class="col-sm-6 text-danger">@Model.Campaign.FailureCount</dd>
                    </dl>
                    @if (Model.Campaign.TotalRecipients > 0)
                    {
                        var pct = (int)(Model.Campaign.ProcessedCount * 100.0 / Model.Campaign.TotalRecipients);
                        <div class="progress mt-2" style="height:8px;" title="@pct% processed">
                            <div class="progress-bar" style="width:@pct%"></div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <!-- Campaign steps -->
    <div class="col-lg-7">
        <div class="card mb-4">
            <div class="card-header">
                <h6 class="mb-0">Campaign Steps (@Model.Campaign.Steps.Count)</h6>
            </div>
            <div class="card-body p-0">
                @if (Model.Campaign.Steps.Any())
                {
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Step</th>
                                <th>Channel</th>
                                <th>Template</th>
                                <th>Delay</th>
                                <th>Executed</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var step in Model.Campaign.Steps)
                            {
                                var channelBadge = step.Channel switch
                                {
                                    "Email"  => "bg-primary",
                                    "Letter" => "bg-warning text-dark",
                                    "Sms"    => "bg-success",
                                    _        => "bg-secondary"
                                };
                                <tr>
                                    <td class="text-center fw-semibold">@step.StepOrder</td>
                                    <td><span class="badge @channelBadge">@step.Channel</span></td>
                                    <td><small>@step.TemplateId</small></td>
                                    <td>
                                        @if (step.DelayDays == 0)
                                        {
                                            <small class="text-muted">Immediate</small>
                                        }
                                        else
                                        {
                                            <small>+@step.DelayDays day(s)</small>
                                        }
                                    </td>
                                    <td>
                                        @if (step.ExecutedAt.HasValue)
                                        {
                                            <small>@step.ExecutedAt.Value.ToString("yyyy-MM-dd HH:mm")</small>
                                        }
                                        else
                                        {
                                            <small class="text-muted">Pending</small>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="p-3 text-muted">No steps defined.</div>
                }
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Campaign.FilterExpression) && Model.Campaign.FilterExpression != "[]")
        {
            <div class="card mb-4">
                <div class="card-header">
                    <a class="text-decoration-none text-body d-flex justify-content-between"
                       data-bs-toggle="collapse" href="#filterExprPanel" role="button">
                        <span><i class="bi bi-funnel"></i> Filter Expression (AST)</span>
                        <i class="bi bi-chevron-down"></i>
                    </a>
                </div>
                <div class="collapse" id="filterExprPanel">
                    <div class="card-body p-0">
                        <pre class="mb-0 p-3 bg-light rounded-bottom small" style="max-height:200px; overflow-y:auto;">@Model.Campaign.FilterExpression</pre>
                    </div>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.Campaign.FreeFieldValues))
        {
            <div class="card mb-4">
                <div class="card-header">
                    <a class="text-decoration-none text-body d-flex justify-content-between"
                       data-bs-toggle="collapse" href="#freeFieldPanel" role="button">
                        <span><i class="bi bi-input-cursor-text"></i> Free Field Values</span>
                        <i class="bi bi-chevron-down"></i>
                    </a>
                </div>
                <div class="collapse" id="freeFieldPanel">
                    <div class="card-body p-0">
                        <pre class="mb-0 p-3 bg-light rounded-bottom small" style="max-height:200px; overflow-y:auto;">@Model.Campaign.FreeFieldValues</pre>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
