@page
@model CampaignEngine.Web.Pages.Campaigns.CampaignIndexModel
@{
    ViewData["Title"] = "Campaigns";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-1">Campaigns</h1>
        <p class="text-muted mb-0">Create and manage targeted message campaigns.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-page="Dashboard" class="btn btn-outline-warning">
            <i class="bi bi-speedometer2"></i> Live Dashboard
        </a>
        @if (User.IsInRole("Operator") || User.IsInRole("Admin"))
        {
            <a asp-page="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> New Campaign
            </a>
        }
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="alert">
        @Model.StatusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@* ------------------------------------------------------------------ *@
@* Dashboard Status Cards (US-027) — shown when no filter is active    *@
@* ------------------------------------------------------------------ *@
@if (string.IsNullOrEmpty(Model.Filter.Status) && string.IsNullOrEmpty(Model.Filter.NameContains))
{
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-4 col-lg-2">
            <a asp-page="Index" asp-route-status="1" class="text-decoration-none">
                <div class="card border-secondary h-100">
                    <div class="card-body text-center py-3">
                        <div class="fs-4 fw-bold text-secondary">@Model.StatusSummary.Draft</div>
                        <div class="small text-muted">Draft</div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <a asp-page="Index" asp-route-status="2" class="text-decoration-none">
                <div class="card border-primary h-100">
                    <div class="card-body text-center py-3">
                        <div class="fs-4 fw-bold text-primary">@Model.StatusSummary.Scheduled</div>
                        <div class="small text-muted">Scheduled</div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <a asp-page="Index" asp-route-status="3" class="text-decoration-none">
                <div class="card border-warning h-100">
                    <div class="card-body text-center py-3">
                        <div class="fs-4 fw-bold text-warning">@Model.StatusSummary.Active</div>
                        <div class="small text-muted">Active</div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <a asp-page="Index" asp-route-status="6" class="text-decoration-none">
                <div class="card border-success h-100">
                    <div class="card-body text-center py-3">
                        <div class="fs-4 fw-bold text-success">@Model.StatusSummary.Completed</div>
                        <div class="small text-muted">Completed</div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <a asp-page="Index" asp-route-status="7" class="text-decoration-none">
                <div class="card border-danger h-100">
                    <div class="card-body text-center py-3">
                        <div class="fs-4 fw-bold text-danger">@Model.StatusSummary.PartialFailure</div>
                        <div class="small text-muted">Partial Failure</div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <a asp-page="Index" asp-route-status="8" class="text-decoration-none">
                <div class="card border-danger h-100">
                    <div class="card-body text-center py-3">
                        <div class="fs-4 fw-bold text-danger">@Model.StatusSummary.ManualReview</div>
                        <div class="small text-muted">Manual Review</div>
                    </div>
                </div>
            </a>
        </div>
    </div>

    @* Active campaigns in-progress panel *@
    @if (Model.ActiveCampaigns.Any())
    {
        <div class="card mb-4 border-warning">
            <div class="card-header bg-warning bg-opacity-10 d-flex justify-content-between align-items-center">
                <span class="fw-semibold">
                    <i class="bi bi-activity text-warning"></i>
                    Active Campaigns (@Model.ActiveCampaigns.Count)
                </span>
                <small class="text-muted">Currently running or processing</small>
            </div>
            <div class="card-body p-0">
                @foreach (var c in Model.ActiveCampaigns)
                {
                    var pct = c.TotalRecipients > 0
                        ? (int)(c.ProcessedCount * 100.0 / c.TotalRecipients)
                        : 0;
                    var barColor = c.FailureCount > 0 && c.TotalRecipients > 0
                        ? (c.FailureCount * 100.0 / c.TotalRecipients >= 10 ? "bg-danger"
                            : c.FailureCount * 100.0 / c.TotalRecipients >= 2 ? "bg-warning"
                            : "bg-success")
                        : "bg-success";
                    <div class="p-3 border-bottom">
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <div>
                                <a asp-page="Detail" asp-route-id="@c.Id" class="fw-semibold text-decoration-none">@c.Name</a>
                                <span class="badge bg-warning text-dark ms-2">@c.Status</span>
                            </div>
                            <small class="text-muted text-nowrap">@c.ProcessedCount / @c.TotalRecipients</small>
                        </div>
                        <div class="progress" style="height: 8px;" title="@pct% processed">
                            <div class="progress-bar @barColor" style="width: @pct%;" role="progressbar"
                                 aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        @if (c.FailureCount > 0)
                        {
                            <small class="text-danger"><i class="bi bi-exclamation-circle"></i> @c.FailureCount failed</small>
                        }
                    </div>
                }
            </div>
        </div>
    }
}

@* ------------------------------------------------------------------ *@
@* Filter Panel                                                         *@
@* ------------------------------------------------------------------ *@
<div class="card mb-4">
    <div class="card-header">
        <h6 class="mb-0">Filters</h6>
    </div>
    <div class="card-body">
        <form method="get" asp-page="Index">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Status</label>
                    <select class="form-select" name="status">
                        <option value="">All Statuses</option>
                        <option value="1" selected="@(Model.Filter.Status == "1")">Draft</option>
                        <option value="2" selected="@(Model.Filter.Status == "2")">Scheduled</option>
                        <option value="3" selected="@(Model.Filter.Status == "3")">Running</option>
                        <option value="4" selected="@(Model.Filter.Status == "4")">Step In Progress</option>
                        <option value="5" selected="@(Model.Filter.Status == "5")">Waiting Next</option>
                        <option value="6" selected="@(Model.Filter.Status == "6")">Completed</option>
                        <option value="7" selected="@(Model.Filter.Status == "7")">Partial Failure</option>
                        <option value="8" selected="@(Model.Filter.Status == "8")">Manual Review</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Name contains</label>
                    <input type="text" class="form-control" name="nameContains" value="@Model.Filter.NameContains" placeholder="Search by name..." />
                </div>
            </div>
            <div class="row mt-3">
                <div class="col">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-search"></i> Search
                    </button>
                    <a asp-page="Index" class="btn btn-outline-secondary ms-2">Clear</a>
                </div>
            </div>
        </form>
    </div>
</div>

@* ------------------------------------------------------------------ *@
@* Results Grid                                                         *@
@* ------------------------------------------------------------------ *@
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Campaigns: <strong>@Model.Total</strong></span>
        <small class="text-muted">Page @Model.Page of @Model.TotalPages</small>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Name</th>
                        <th>Status</th>
                        <th>Progress</th>
                        <th>Data Source</th>
                        <th>Steps</th>
                        <th>Scheduled</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.Items)
                    {
                        var statusBadge = c.Status switch
                        {
                            "Draft"         => "bg-secondary",
                            "Scheduled"     => "bg-primary",
                            "Running"       => "bg-warning text-dark",
                            "StepInProgress"=> "bg-warning text-dark",
                            "WaitingNext"   => "bg-info text-dark",
                            "Completed"     => "bg-success",
                            "PartialFailure"=> "bg-danger",
                            "ManualReview"  => "bg-danger",
                            _               => "bg-secondary"
                        };
                        var pct = c.TotalRecipients > 0
                            ? (int)(c.ProcessedCount * 100.0 / c.TotalRecipients)
                            : 0;
                        <tr>
                            <td>
                                <a asp-page="Detail" asp-route-id="@c.Id" class="fw-semibold text-decoration-none">@c.Name</a>
                                @if (!string.IsNullOrEmpty(c.CreatedBy))
                                {
                                    <br/><small class="text-muted">by @c.CreatedBy</small>
                                }
                            </td>
                            <td><span class="badge @statusBadge">@c.Status</span></td>
                            <td style="min-width: 120px;">
                                @if (c.TotalRecipients > 0)
                                {
                                    <div class="progress" style="height:6px;" title="@pct% processed — @c.FailureCount failed">
                                        <div class="progress-bar @(c.FailureCount > 0 ? "bg-warning" : "bg-success")"
                                             style="width:@pct%"></div>
                                    </div>
                                    <small class="text-muted">@c.ProcessedCount/@c.TotalRecipients
                                        @if (c.FailureCount > 0)
                                        {
                                            <span class="text-danger">(@c.FailureCount failed)</span>
                                        }
                                    </small>
                                }
                                else
                                {
                                    <small class="text-muted">—</small>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(c.DataSourceName))
                                {
                                    <small>@c.DataSourceName</small>
                                }
                                else
                                {
                                    <small class="text-muted">—</small>
                                }
                            </td>
                            <td class="text-center">@c.Steps.Count</td>
                            <td class="text-nowrap">
                                @if (c.ScheduledAt.HasValue)
                                {
                                    <small>@c.ScheduledAt.Value.ToString("yyyy-MM-dd HH:mm")</small>
                                }
                                else
                                {
                                    <small class="text-muted">Immediate</small>
                                }
                            </td>
                            <td class="text-nowrap">
                                <small>@c.CreatedAt.ToString("yyyy-MM-dd HH:mm")</small>
                            </td>
                            <td class="text-nowrap">
                                <a asp-page="Detail" asp-route-id="@c.Id" class="btn btn-sm btn-outline-secondary">View</a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Items.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                No campaigns match the current filters.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* Pagination *@
    @if (Model.TotalPages > 1)
    {
        <div class="card-footer d-flex justify-content-between align-items-center">
            <small class="text-muted">
                Showing @((Model.Page - 1) * Model.PageSize + 1)–@(Math.Min(Model.Page * Model.PageSize, Model.Total)) of @Model.Total
            </small>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    @if (Model.Page > 1)
                    {
                        <li class="page-item">
                            <a class="page-link"
                               asp-page="Index"
                               asp-route-page="@(Model.Page - 1)"
                               asp-route-status="@Model.Filter.Status"
                               asp-route-nameContains="@Model.Filter.NameContains">Previous</a>
                        </li>
                    }
                    @if (Model.Page < Model.TotalPages)
                    {
                        <li class="page-item">
                            <a class="page-link"
                               asp-page="Index"
                               asp-route-page="@(Model.Page + 1)"
                               asp-route-status="@Model.Filter.Status"
                               asp-route-nameContains="@Model.Filter.NameContains">Next</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>
